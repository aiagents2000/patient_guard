# PatientGuard Backend — Environment Variables
# Copia questo file in .env e compila i valori

# Supabase (opzionale — senza, usa JSON demo)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# LLM Provider (opzionale — senza, il riassunto non è disponibile)
OPENAI_API_KEY=sk-your-key
# oppure
# ANTHROPIC_API_KEY=sk-ant-your-key

# App
DEBUG=false
LOG_LEVEL=info
